{
  "log_file": "orchestrator.log",
  "api_port": 8090,
  "containers": [
    {
      "name": "echo-svc",
      "command": "echo",
      "args": ["hello from echo-svc"],
      "restart_policy": "always",
      "max_restarts": 5,
      "health_check": {
        "command": "echo",
        "args": ["ok"],
        "interval_sec": 10,
        "timeout_sec": 3,
        "retries": 3
      }
    },
    {
      "name": "timer-svc",
      "command": "go",
      "args": ["version"],
      "restart_policy": "on-failure",
      "max_restarts": 3
    },
    {
      "name": "ping-svc",
      "command": "ping",
      "args": ["-c", "3", "127.0.0.1"],
      "restart_policy": "never",
      "health_check": {
        "command": "ping",
        "args": ["-c", "1", "127.0.0.1"],
        "interval_sec": 15,
        "timeout_sec": 5,
        "retries": 2
      }
    }
  ]
}